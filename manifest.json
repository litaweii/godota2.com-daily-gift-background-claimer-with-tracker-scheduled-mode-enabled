{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.2.0",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": [
    "https://steamcommunity.com/*",
    "https://godota2.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://steamcommunity.com/*/edit/info*",
        "https://steamcommunity.com/openid/login*"
      ],
      "js": ["steam-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://godota2.com/*"],
      "js": ["godota-content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
